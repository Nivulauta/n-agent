{
    "name": "backend-integration-tests",
    "version": "1.0.0",
    "description": "Integration tests for Nivulauta Agent backend services",
    "type": "module",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:error-resilience": "vitest run error-resilience.test.ts",
        "test:performance": "vitest run performance-benchmarks.test.ts",
        "test:verbose": "vitest run --reporter=verbose",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@aws-sdk/client-api-gateway": "^3.1006.0",
        "@aws-sdk/client-apigatewayv2": "^3.1006.0",
        "@aws-sdk/client-bedrock-runtime": "^3.705.0",
        "@aws-sdk/client-cloudwatch-logs": "^3.1006.0",
        "@aws-sdk/client-dynamodb": "^3.705.0",
        "@aws-sdk/client-iam": "^3.1006.0",
        "@aws-sdk/client-opensearch": "^3.705.0",
        "@aws-sdk/client-s3": "^3.705.0",
        "@aws-sdk/credential-provider-node": "^3.705.0",
        "@aws-sdk/util-dynamodb": "^3.705.0",
        "@opensearch-project/opensearch": "^2.12.0",
        "jsonwebtoken": "^9.0.2",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.10.2",
        "@types/ws": "^8.5.13",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    }
}